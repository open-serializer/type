{
    "name": "open-serializer/type",
    "description": "PHP Type Tools",
    "type": "library",
    "require": {
        "php": "^7.4 || ^8.0",
        "ext-json": "*",
        "phpdocumentor/reflection-docblock": "^6.0",
        "webmozart/assert": "^2.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "phpstan/phpstan": "^2.1",
        "vimeo/psalm": "^6.16",
        "phpstan/phpstan-phpunit": "^2.0"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "OpenSerializer\\Type\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OpenSerializer\\Type\\Tests\\": "tests/"
        }
    }
}
